# Backend base URL (no trailing slash). Vite dev proxy forwards /api here when configured.
VITE_API_URL=http://localhost:3001

# Expected REST endpoints (when you implement the server):
# POST /api/contact          — body: { name, email, subject, message }
# POST /api/subscribe        — body: { email, source }
# GET  /api/articles/:id
# GET  /api/articles/:id/comments
# POST /api/articles/:id/comments — body: { body, author? }
